# Dev Mode (set to "true" to enable fake auth without Discord)
DEV_MODE=false

# Discord OAuth2 (not required when DEV_MODE=true)
DISCORD_CLIENT_ID=your_discord_app_client_id
DISCORD_CLIENT_SECRET=your_discord_app_client_secret
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# JWT
JWT_SECRET=your_random_jwt_secret_here

# Game Config (filename in server/config/games/)
GAME_CONFIG=_template.json

# Allowed frontend origin for CORS (must match where the client is served from)
CLIENT_ORIGIN=http://localhost:5173

# Server
PORT=3000
